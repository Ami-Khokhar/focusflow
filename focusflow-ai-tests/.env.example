# FocusFlow AI Test Suite — Environment Variables
# Copy this file to .env and fill in real values

# URL of the running FocusFlow dev/staging server
FOCUSFLOW_URL=http://localhost:3000

# Supabase connection (use a SERVICE ROLE key so the test suite can bypass RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Groq API keys (used by the core app and test suite agents)
# Provide multiple keys (up to GROQ_API_KEY_10) to rotate load and avoid 429 rate limits
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_KEY_2=your-second-api-key-here

# Test configuration
TEST_TIMEOUT_MS=30000
TEST_USER_PREFIX=ai-test-
