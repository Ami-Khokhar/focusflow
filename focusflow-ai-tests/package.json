{
  "name": "focusflow-ai-tests",
  "version": "1.0.0",
  "description": "AI-powered QA testing system for FocusFlow — simulates ADHD users, evaluates coaching quality, and detects DB bugs.",
  "type": "module",
  "main": "tests/runTests.js",
  "scripts": {
    "test": "node tests/runTests.js",
    "test:random": "node tests/runTests.js --random",
    "test:long": "node tests/runTests.js --long",
    "test:matrix": "node tests/runTests.js --matrix",
    "test:matrix:quick": "node tests/runTests.js --matrix --max-variants 2",
    "test:flex": "node tests/runTests.js --flex --shuffle --repeat 2",
    "test:flex:quick": "node tests/runTests.js --flex --max-runs 16 --shuffle"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.42.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "groq-sdk": "^0.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
